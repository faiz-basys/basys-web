# Copy to ".env.local" (Next.js) or ".env" and fill in real values.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# --- SMTP (Nodemailer) — used for /career/apply submissions ---
# Examples: smtp.office365.com, smtp.gmail.com, or your provider’s host
SMTP_HOST=your.smtp.host.example

# 587 with STARTTLS is typical; 465 often uses SMTP_SECURE=true
SMTP_PORT=587

# "true" = SSL (e.g. port 465). "false" = STARTTLS on 587 (most common)
SMTP_SECURE=false

# Mailbox used to authenticate to SMTP (leave empty only if your relay allows unauthenticated send)
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password-or-app-password

# Where applications are delivered (HR / communications inbox). Comma-separated for multiple.
CAREERS_TO=hr@basys.ai

# Optional "From" header (defaults to SMTP_USER, then CAREERS_TO). Must be allowed by your mail provider.
CAREERS_FROM=careers-noreply@basys.ai

# Optional: dedicated inboxes for site forms. If unset, CONTACT_TO / WHITEPAPER_TO fall back to CAREERS_TO.
CONTACT_TO=communications@basys.ai
WHITEPAPER_TO=communications@basys.ai
